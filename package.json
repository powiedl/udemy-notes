{
  "name": "udemy-notes",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "vercel-build": "prisma generate && prisma migrate deploy && pnpm run build",
    "build": "vite build",
    "build:local": "dotenv -e .env.production.local pnpm run build",
    "start:local": "node --env-file=.env.production.local .output/server/index.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "eslint",
    "format": "prettier --check .",
    "check": "prettier --write . && eslint --fix",
    "post-cta-init": "npx -y create-db@latest --user-agent tanstack/tsrouter",
    "prod:db:generate": "dotenv -e .env.production.local -- prisma generate",
    "prod:db:deploy": "dotenv -e .env.production.local -- prisma migrate deploy",
    "prod:db:studio": "dotenv -e .env.production.local -- prisma studio",
    "prod:db:seed": "dotenv -e .env.production.local -- prisma db seed",
    "db:generate": "dotenv -e .env.development.local -- prisma generate",
    "db:push": "dotenv -e .env.development.local -- prisma db push",
    "db:migrate": "dotenv -e .env.development.local -- prisma migrate dev",
    "db:studio": "dotenv -e .env.development.local -- prisma studio",
    "db:push:force": "dotenv -e .env.development.local -- prisma db push --force-reset",
    "db:seed": "dotenv -e .env.development.local -- prisma db seed",
    "db:cleanup-trainers": "dotenv -e .env.development.local -- tsx src/scripts/cleanup-trainers.ts"
  },
  "dependencies": {
    "@fontsource-variable/dm-sans": "^5.2.8",
    "@fontsource-variable/geist": "^5.2.8",
    "@hugeicons/core-free-icons": "^4.0.0",
    "@hugeicons/react": "^1.1.6",
    "@mdxeditor/editor": "^3.55.0",
    "@openrouter/sdk": "^0.12.35",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-form": "^1.28.5",
    "@tanstack/react-query": "^5.96.0",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/router-plugin": "^1.132.0",
    "@tanstack/zod-adapter": "^1.166.9",
    "better-auth": "^1.5.5",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^0.545.0",
    "nitro": "3.0.260311-beta",
    "pnpm": "^11.2.0",
    "prisma": "^7.4.2",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "shadcn": "^4.1.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/devtools-vite": "latest",
    "@tanstack/eslint-config": "latest",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.1.4",
    "dotenv-cli": "^11.0.0",
    "jsdom": "^29.0.2",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.0.5",
    "vitest-mock-extended": "^4.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
