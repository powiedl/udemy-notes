generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// #region Better-Auth
model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean   @default(false) @map("email_verified")
  image         String?
  role          String?   @default("user")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  sessions      Session[]
  accounts      Account[]
  courses       Course[]
  notes         Note[]
  tags          Tag[]
  logs          Log[]

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime @map("expires_at")
  token     String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  userId                String    @map("user_id")
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  idToken               String?   @map("id_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([identifier])
  @@map("verification")
}

// #endregion

// #region Udemy Notes

model Course {
  id        String          @id @default(uuid())
  title     String
  trainers  CourseTrainer[]
  userId    String          @map("user_id")
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  notes     Note[]
  tags      CourseTag[]
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")

  @@map("course")
}

model Note {
  id       String @id @default(uuid())
  courseId String @map("course_id")
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  userId   String @map("user_id")
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Metadaten vom Udemy Import
  timestamp String // z.B. "03:45"
  section   String
  lecture   String

  orderInfo       String @default("0-0-0") @map("order_info") // sectionnumber-lecturenumber-timestampInSeconds (3-23-456)
  // Content-Logik
  originalContent String @map("original_content") @db.Text
  editedContent   String @default("") @map("edited_content") @db.Text

  // Status
  isPublic    Boolean @default(false) @map("is_public")
  hasConflict Boolean @default(false) @map("has_conflict") // die Notiz in Udemy hat sich geändert, und der User hat die Notiz auch in der App geändert
  isDeleted   Boolean @default(false) @map("is_deleted")

  // Tags (Many-to-Many via impliziter Tabelle in Prisma)
  tags NoteTag[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("note")
}

model Trainer {
  id      String          @id @default(cuid())
  name    String          @unique // Damit "Maximilian Müller" nur einmal existiert
  courses CourseTrainer[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("trainer")
}

// Explizite Join-Table (erlaubt später mehr Flexibilität)
model CourseTrainer {
  courseId  String
  trainerId String
  course    Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  trainer   Trainer @relation(fields: [trainerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@id([courseId, trainerId])
  @@map("course_to_trainer")
}

model Tag {
  id        String      @id @default(uuid())
  name      String
  notes     NoteTag[]
  userId    String?     @map("user_id")
  user      User?       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")
  courses   CourseTag[]

  @@unique([name, userId])
  @@map("tag")
}

model NoteTag {
  noteId String @map("note_id")
  tagId  String @map("tag_id")

  note Note @relation(fields: [noteId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([noteId, tagId])
  @@map("note_to_tag")
}

model CourseTag {
  courseId String @map("course_id")
  tagId    String @map("tag_id")

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([courseId, tagId])
  @@map("course_to_tag")
}

model Log {
  id             String  @id @default(uuid())
  component      String? // Frontend-Komponente (optional beim Aufruf)
  serverFunction String? @map("server_function") // Name der Server Function (automatisch)
  severity       String? // info, warning, error, critical
  message        String? // Fehlermeldung oder Info-Text
  feature        String? // Feature, das den Fehler ausgelöst hat
  actionSource   String? @map("action_source") // Element, dass den Fehler ausgelöst hat, z. b. der Button, auf den man klickt
  correlationId  String? @map("correlation_id")
  requestId      String? @map("request_id")

  userId String? @map("user_id")
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("log")
}
